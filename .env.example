# Required
OPENROUTER_API_KEY=sk-or-...

# Optional: Multi-writer auth tokens
# Format: token1:agent-name1,token2:agent-name2
WRITER_TOKENS=
ADMIN_TOKEN=

# Free distillable mode (default: true)
FREE_DISTILLABLE_MODE=true

# Expansion settings
EXPANSION_ENABLED=true
EXPANSION_DAILY_BUDGET=0
EXPANSION_INTERVAL=600

# Database (default uses docker-compose postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/hermes_clockchain
